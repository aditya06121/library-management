datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String    @id @default(uuid())
  name     String
  email    String    @unique
  password String
  sessions Session[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
